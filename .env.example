# Server Configuration
PORT=3000
NODE_ENV=development

# MySQL Database Connection (Sequelize)
MYSQLHOST=localhost
MYSQLPORT=3306
MYSQLUSER=root
MYSQLPASSWORD=your_mysql_password
MYSQLDATABASE=app_retail_saas
MYSQL_URL=mysql://root:your_mysql_password@localhost:3306/app_retail_saas

# JWT Secret & Expiration
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRES_IN=24h

# Supabase Storage & Bucket (For Product Images and Receipts)
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_KEY=your_supabase_anon_or_service_key
SUPABASE_SERVICE_KEY=your_supabase_service_key
SUPABASE_BUCKET=comprobantes

# Clerk Authentication (Optional / Third-party)
CLERK_SECRET_KEY=your_clerk_secret_key
